# MASTER_PASSWORD: Required for production. Global app password checked only on the server.
# Never put this in frontend code or VITE_* vars — it must stay server-side.
MASTER_PASSWORD=change-me

# SESSION_SECRET: Optional. Used to sign session cookies. Defaults to MASTER_PASSWORD if unset.
SESSION_SECRET=

# COOKIE_SECURE: Set to "true" only when serving over HTTPS so the session cookie uses Secure.
COOKIE_SECURE=false

# GEMINI_API_KEY: Optional. Enables AI sales pitch generation.
GEMINI_API_KEY=

# PORT: HTTP port the server listens on (default 3000).
PORT=3000

# DATA_DIR: Directory for persistent lead storage (default ./data).
# In Docker this is set to /data and backed by a volume.
DATA_DIR=./data

# APP_URL: Public URL of the app (optional).
APP_URL=
